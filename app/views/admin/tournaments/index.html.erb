<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
  <h1>⛳ Tournaments</h1>
  <%= link_to "＋ New Tournament", new_admin_tournament_path, class: "btn btn-primary" %>
</div>
<p class="subtitle">Manage BirdieBoard tournaments — invite players, set up rounds, track scores.</p>

<% if @tournaments.empty? %>
  <div class="card" style="text-align:center;padding:48px 24px;">
    <div style="font-size:48px;margin-bottom:12px;">⛳</div>
    <div style="font-size:16px;font-weight:600;margin-bottom:6px;">No tournaments yet</div>
    <div style="color:var(--text-muted);font-size:13px;margin-bottom:20px;">Create your first tournament and invite players via magic link.</div>
    <%= link_to "Create Tournament", new_admin_tournament_path, class: "btn btn-primary" %>
  </div>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Tournament</th>
        <th>Date</th>
        <th>Format</th>
        <th>Entries</th>
        <th>State</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @tournaments.each do |t| %>
        <tr>
          <td>
            <div style="font-weight:600;"><%= t.name %></div>
            <div style="font-size:12px;color:var(--text-muted);"><%= t.location %></div>
          </td>
          <td><%= t.date&.strftime("%-d %b %Y") || "—" %></td>
          <td style="text-transform:capitalize;"><%= t.format %></td>
          <td><%= t.entries.count %> / <%= t.invitations.accepted.count %> invited</td>
          <td><span class="badge badge-<%= t.state %>"><%= t.state %></span></td>
          <td style="text-align:right;">
            <%= link_to "Manage", admin_tournament_path(t), class: "btn btn-secondary btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
