<% invite_token = params[:invite] || session[:pending_invitation_token] %>
<% invitation  = Invitation.find_by(token: invite_token) if invite_token.present? %>
<% is_golf     = invite_token.present? %>

<% if is_golf && invitation %>
  <div class="invite-banner">
    <div class="icon">⛳</div>
    <div class="text">
      <div class="t-name">Sign in to join <%= invitation.tournament.name %></div>
      <div class="t-sub">
        <%= [invitation.tournament.date&.strftime("%-d %B %Y"), invitation.tournament.location].compact.join(" · ") %>
      </div>
    </div>
  </div>
<% end %>

<h2><%= is_golf ? "Welcome back" : "Sign in" %></h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), data: { turbo: false }) do |f| %>
  <%= hidden_field_tag :invite, invite_token if is_golf %>

  <div class="field">
    <%= f.label :email, "Email", class: is_golf ? "lbl" : nil %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
        value: invitation&.email %>
  </div>

  <div class="field">
    <%= f.label :password, "Password", class: is_golf ? "lbl" : nil %>
    <%= f.password_field :password, autocomplete: "current-password" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="check-row">
      <%= f.check_box :remember_me %>
      <%= f.label :remember_me, "Keep me signed in" %>
    </div>
  <% end %>

  <%= f.submit is_golf ? "Sign In & Accept Invitation" : "Sign in",
      class: is_golf ? "btn-submit" : "btn-primary" %>
<% end %>

<div class="auth-links">
  <%= link_to "Forgot your password?", new_password_path(resource_name) %>
  <% if is_golf %>
    <%= link_to "Don't have an account? Create one",
        new_registration_path(resource_name, invite: invite_token) %>
  <% end %>
</div>
